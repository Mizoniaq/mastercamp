.env
.env.*
!.env.example
.streamlit/secrets.toml

# ── Artefacts générés à l'exécution ──────────────────────────────────────
tmp_uploads/
*.sqlite
*.sqlite3
*.log
eval/outputs/

# ── Données réelles : jamais commitées (seul le guide est suivi) ─────────

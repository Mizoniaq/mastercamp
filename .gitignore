# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ── Environnements virtuels ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Outils / caches ──────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.ipynb_checkpoints/

# ── IDE / OS / outils ────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# ── Secrets & variables d'environnement ──────────────────────────────────

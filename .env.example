# Copiez ce fichier en `.env` et renseignez vos valeurs. Ne commitez jamais `.env`.

# Token Hugging Face — requis UNIQUEMENT pour le connecteur MedGemma réel
# (src.inference.medgemma_predict). Le mode jouet par défaut n'en a pas besoin.
HF_TOKEN=

# Chemin de la base SQLite de preuves (logs des prédictions).
# Optionnel — défaut : medical_ai_evidence.sqlite à la racine du dépôt.
EVIDENCE_DB_PATH=
